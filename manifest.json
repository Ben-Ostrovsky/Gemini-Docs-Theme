{
  "manifest_version": 3,
  "name": "Gemini Stealth Theme",
  "description": "Re-theme gemini.google.com to look like Docs for stealth use.",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://gemini.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gemini Stealth"
  }
}
