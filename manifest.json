{
  "manifest_version": 3,
  "name": "Gemini Docs Theme",
  "description": "A Docs-style writing theme for gemini.google.com. Not affiliated with Google.",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://gemini.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gemini Docs Theme"
  }
}
